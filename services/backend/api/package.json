{
  "name": "@professor-connect/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src tests --max-warnings=0",
    "predev": "npm run build --workspace=@professor-connect/protocol --workspace=@professor-connect/services --workspace=@professor-connect/config --workspace=@professor-connect/websocket",
    "start": "node dist/server.js",
    "test": "tsx --test tests/health.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@professor-connect/config": "0.1.0",
    "@professor-connect/websocket": "0.1.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "tsx": "4.23.1"
  }
}
