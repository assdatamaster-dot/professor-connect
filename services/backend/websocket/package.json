{
  "name": "@professor-connect/websocket",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "client:test": "tsx tests/communication-client.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src tests --max-warnings=0",
    "pretest": "npm run build --workspace=@professor-connect/protocol --workspace=@professor-connect/services",
    "presence:client": "tsx tests/presence-client.ts",
    "request:client": "tsx tests/request-client.ts",
    "test": "tsx --test tests/active-session.spec.ts tests/communication.spec.ts tests/heartbeat.spec.ts tests/presence.spec.ts tests/professor-presence.spec.ts tests/remote-control-channel.spec.ts tests/request.spec.ts tests/session.spec.ts tests/session-request.spec.ts tests/session-request-flow.spec.ts tests/signaling.spec.ts tests/student-presence.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@professor-connect/services": "0.1.0",
    "@professor-connect/protocol": "0.1.0",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "socket.io-client": "4.8.3",
    "tsx": "4.23.1"
  }
}
