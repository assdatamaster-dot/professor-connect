# Backend
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
REQUEST_TIMEOUT_MS=60000
HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_TIMEOUT_MS=90000
RECONNECT_WINDOW_MS=90000

# Docker Compose production publishing
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=3000
PROFESSOR_CONNECT_IMAGE=professor-connect-backend:0.1.0

# WebRTC client configuration. TURN is recommended across restrictive NATs.
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_ENABLED=false
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Reserved for the Prisma workspace; the Beta-1A backend does not connect to it.
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/professor_connect
