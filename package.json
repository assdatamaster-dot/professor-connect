{
  "name": "professor-connect",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo do Professor Connect.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "npm run lint && npm run typecheck && npm run format:check",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.0",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0"
  }
}
