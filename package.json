{
  "name": "professor-connect",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo do Professor Connect.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/backend/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build-all": "npm run build-student && npm run build-teacher",
    "build-backend": "turbo run build --filter=@professor-connect/api...",
    "build-student": "npm run dist:win --workspace=@professor-connect/student-electron",
    "build-teacher": "npm run dist:win --workspace=@professor-connect/teacher-electron",
    "check": "npm run lint && npm run typecheck && npm run test && npm run format:check",
    "clean": "turbo run clean",
    "communication:client": "npm run client:test --workspace=@professor-connect/websocket",
    "dev": "npm run dev --workspace=@professor-connect/api",
    "desktop:student": "npm run dev --workspace=@professor-connect/student-electron",
    "desktop:teacher": "npm run dev --workspace=@professor-connect/teacher-electron",
    "deploy-production": "node scripts/deploy-production.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "prisma:generate": "npm run prisma:generate --workspace=@professor-connect/database",
    "presence:client": "npm run presence:client --workspace=@professor-connect/websocket",
    "request:client": "npm run request:client --workspace=@professor-connect/websocket",
    "start": "npm run start --workspace=@professor-connect/api",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "electron-builder": "26.15.3",
    "eslint": "10.0.0",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0"
  }
}
