{
  "name": "@professor-connect/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src tests --max-warnings=0",
    "pretest": "npm run build --workspace=@professor-connect/protocol --workspace=@professor-connect/services",
    "test": "tsx --test --test-force-exit tests/webrtc.spec.ts tests/data-channel.spec.ts tests/rtc-engine.spec.ts tests/screen-sharing.spec.ts tests/remote-control.spec.ts tests/workflow.spec.ts tests/end-to-end.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@professor-connect/services": "0.1.0",
    "@professor-connect/protocol": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "@roamhq/wrtc": "0.10.0"
  }
}
