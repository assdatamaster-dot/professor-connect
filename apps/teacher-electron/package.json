{
  "name": "@professor-connect/teacher-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicativo desktop do professor para atendimentos no Professor Connect.",
  "author": {
    "name": "Professor Connect"
  },
  "productName": "Professor Connect - Professor",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p preload/tsconfig.json && tsc -p tsconfig.json && node scripts/copy-static.mjs && node ../../scripts/validate-renderer-esm.mjs dist/renderer/presence.js",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "npm run build && electron .",
    "dist:win": "npx turbo run build --filter=@professor-connect/teacher-electron... && electron-builder --win nsis --x64",
    "lint": "eslint main preload renderer shared tests --max-warnings=0",
    "start": "electron .",
    "test": "tsx --test tests/*.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p preload/tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@professor-connect/engine": "0.1.0",
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "electron": "43.1.1",
    "tsx": "4.23.1"
  },
  "build": {
    "appId": "br.com.professorconnect.teacher",
    "productName": "Professor Connect - Professor",
    "copyright": "Copyright (c) 2026 Professor Connect",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "buildResources": "assets",
      "output": "../../release/teacher"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.svg",
      "executableName": "Professor Connect Professor",
      "legalTrademarks": "Professor Connect"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Professor Connect - Professor",
      "uninstallDisplayName": "Professor Connect - Professor",
      "artifactName": "Professor-Connect-Professor-Setup-${version}-${arch}.${ext}"
    }
  }
}
